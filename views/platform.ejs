<%- include('partials/head', { title: 'Platform' }) %>
<%- include('partials/nav', { page: 'platform' }) %>

<!-- PAGE HERO -->
<section class="page-hero">
  <div class="hero-inner">
    <div class="hero-badge"><span class="badge-dot"></span> PLATFORM OVERVIEW</div>
    <h1 class="hero-title">Everything You Need<br />to <em>Hire Smarter</em></h1>
    <p class="hero-sub">One end-to-end AI platform that replaces your entire screening pipeline — from job description to ranked shortlist.</p>
    <div class="hero-cta">
      <a href="/pricing" class="btn-primary">Get Started →</a>
      <a href="/contact" class="btn-secondary">Book a Demo</a>
    </div>
  </div>
</section>

<!-- FEATURES DEEP DIVE -->
<section class="platform-features">
  <div class="section-inner">
    <!-- Feature 1 -->
    <div class="feature-row">
      <div class="feature-text">
        <p class="section-tag">JD GENERATOR</p>
        <h2>Bias-Free Job Descriptions in Seconds</h2>
        <p>Describe the role in plain English and our AI generates a fully structured, legally compliant, bias-free job description. No more copy-pasting last year's posting.</p>
        <ul class="feature-list">
          <li>✓ Removes gendered and exclusionary language</li>
          <li>✓ Suggests inclusive requirements</li>
          <li>✓ SEO-optimised for job boards</li>
          <li>✓ Exportable to any ATS in one click</li>
        </ul>
      </div>
      <div class="feature-visual">
        <div class="mock-card">
          <div class="mock-header"><span class="mock-dot red"></span><span class="mock-dot yellow"></span><span class="mock-dot green"></span></div>
          <div class="mock-line wide"></div>
          <div class="mock-line medium"></div>
          <div class="mock-line short"></div>
          <div class="mock-badge">✓ Bias-Free</div>
        </div>
      </div>
    </div>

    <!-- Feature 2 -->
    <div class="feature-row reverse">
      <div class="feature-text">
        <p class="section-tag">AI INTERVIEWS</p>
        <h2>Avatar-Led Interviews at Any Scale</h2>
        <p>Deploy hundreds of simultaneous structured interviews led by realistic AI avatars. Every candidate gets the same quality experience — regardless of when they apply.</p>
        <ul class="feature-list">
          <li>✓ Custom question sets per role</li>
          <li>✓ Async video interviews — candidate's own time</li>
          <li>✓ Consistent, legally defensible process</li>
          <li>✓ Supports 30+ languages</li>
        </ul>
      </div>
      <div class="feature-visual">
        <div class="mock-card avatar-card">
          <div class="avatar-circle">🤖</div>
          <div class="mock-line medium" style="margin:12px auto 8px;"></div>
          <div class="mock-line short" style="margin:0 auto;"></div>
          <div class="avatar-chips">
            <span class="chip">📹 Recording</span>
            <span class="chip">🌐 EN</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Feature 3 -->
    <div class="feature-row">
      <div class="feature-text">
        <p class="section-tag">SCORING ENGINE</p>
        <h2>4-Dimension Candidate Scoring</h2>
        <p>Every interview response is scored across four dimensions by our proprietary AI model — giving hiring managers an objective, auditable ranking.</p>
        <ul class="feature-list">
          <li>✓ Communication clarity</li>
          <li>✓ Technical depth & relevance</li>
          <li>✓ Culture-add signals</li>
          <li>✓ Problem-solving approach</li>
        </ul>
      </div>
      <div class="feature-visual">
        <div class="mock-card score-card">
          <div class="score-row"><span>Communication</span><div class="score-bar"><div class="score-fill" style="width:88%"></div></div><span>88</span></div>
          <div class="score-row"><span>Technical</span><div class="score-bar"><div class="score-fill" style="width:76%"></div></div><span>76</span></div>
          <div class="score-row"><span>Culture Fit</span><div class="score-bar"><div class="score-fill" style="width:92%"></div></div><span>92</span></div>
          <div class="score-row"><span>Problem Solving</span><div class="score-bar"><div class="score-fill" style="width:81%"></div></div><span>81</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- INTEGRATIONS -->
<section class="integrations">
  <div class="section-inner" style="text-align:center">
    <p class="section-tag">INTEGRATIONS</p>
    <h2 class="section-title">Plugs Into Your Existing Stack</h2>
    <div class="integration-logos">
      <div class="int-logo">Greenhouse</div>
      <div class="int-logo">Lever</div>
      <div class="int-logo">Workday</div>
      <div class="int-logo">BambooHR</div>
      <div class="int-logo">Slack</div>
      <div class="int-logo">Zapier</div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-banner">
  <div class="section-inner cta-inner">
    <h2>See the platform in action</h2>
    <p>Book a 30-minute live demo with our team — no commitment required.</p>
    <div class="cta-btns">
      <a href="/contact" class="btn-primary">Book a Demo →</a>
      <a href="/pricing" class="btn-outline">View Pricing</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
