<!-- FAQ -->
<section class="faq">
  <div class="section-inner">
    <p class="section-tag" style="text-align:center">FAQ</p>
    <h2 class="section-title" style="text-align:center">Frequently Asked Questions</h2>
    <div class="faq-list">
      <div class="faq-item">
        <button class="faq-q">Can I change plans at any time?</button>
        <div class="faq-a">Yes — upgrade or downgrade at any time. Changes take effect at the start of your next billing cycle.</div>
      </div>
      <div class="faq-item">
        <button class="faq-q">Is there a free trial?</button>
        <div class="faq-a">All plans include a 14-day free trial with no credit card required. You get full access to every feature on your chosen tier.</div>
      </div>
      <div class="faq-item">
        <button class="faq-q">What counts as one AI Interview?</button>
        <div class="faq-a">One AI Interview = one candidate completing a full structured interview session for a role. Partial or incomplete sessions are not counted.</div>
      </div>
      <div class="faq-item">
        <button class="faq-q">Do you offer annual billing discounts?</button>
        <div class="faq-a">Yes — pay annually and save 20% on Starter and Growth plans. Contact us for Enterprise annual pricing.</div>
      </div>
    </div>
  </div>
</section>

