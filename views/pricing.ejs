<!-- PAGE HERO -->
<section class="pricing-hero">
  <div class="section-inner">
    <p class="pricing-tag">PRICING</p>
    <h1 class="pricing-headline">Predictable pricing. No per-seat surprises.</h1>
    <hr class="pricing-divider" />
  </div>
</section>

<!-- PRICING CARDS -->
<section class="pricing" style="padding-top:0">
  <div class="section-inner">
    <div class="pricing-grid">

      <!-- STARTER -->
      <div class="price-card">
        <h3 class="plan-label">STARTER</h3>
        <div class="price">&#8377;9,999</div>
        <p class="price-meta">per month · up to 3 active roles</p>
        <p class="price-desc">For startups running lean hiring with limited roles.</p>
        <ul>
          <li><span class="check green">&#10004;</span> 50 AI interviews/month</li>
          <li><span class="check green">&#10004;</span> AI JD Generator</li>
          <li><span class="check green">&#10004;</span> Basic scoring (Fit + Trust)</li>
          <li><span class="check green">&#10004;</span> All sessions recorded</li>
          <li><span class="check green">&#10004;</span> Email support</li>
        </ul>
        <a href="/contact" class="btn-price">Get Started</a>
      </div>

      <!-- GROWTH -->
      <div class="price-card featured">
        <div class="popular-badge">RECOMMENDED</div>
        <h3 class="plan-label">GROWTH</h3>
        <div class="price">&#8377;29,999</div>
        <p class="price-meta">per month · up to 15 active roles</p>
        <p class="price-desc">For high-growth teams hiring across multiple departments.</p>
        <ul>
          <li><span class="check teal">&#10004;</span> 300 AI interviews/month</li>
          <li><span class="check teal">&#10004;</span> All 4 score dimensions</li>
          <li><span class="check teal">&#10004;</span> Full proctoring suite</li>
          <li><span class="check teal">&#10004;</span> ATS integration (20+ platforms)</li>
          <li><span class="check teal">&#10004;</span> Bulk invitations &amp; scheduling</li>
          <li><span class="check teal">&#10004;</span> Priority support + CSM</li>
        </ul>
        <a href="/contact" class="btn-price">Start Free Trial</a>
      </div>

      <!-- ENTERPRISE -->
      <div class="price-card">
        <h3 class="plan-label">ENTERPRISE</h3>
        <div class="price">Custom</div>
        <p class="price-meta">tailored to your org size &amp; needs</p>
        <p class="price-desc">Unlimited scale, dedicated infrastructure, white-glove onboarding.</p>
        <ul>
          <li><span class="check green">&#10004;</span> Unlimited interviews</li>
          <li><span class="check green">&#10004;</span> Custom AI question banks</li>
          <li><span class="check green">&#10004;</span> Dedicated cloud instance</li>
          <li><span class="check green">&#10004;</span> SSO / SAML &amp; RBAC</li>
          <li><span class="check green">&#10004;</span> Custom analytics &amp; reporting</li>
          <li><span class="check green">&#10004;</span> SLA + dedicated support</li>
        </ul>
        <a href="/contact" class="btn-price">Talk to Sales</a>
      </div>

    </div>
  </div>
</section>

